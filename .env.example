# ============================================================
# 云想衣裳 - 环境变量模板
# 复制本文件为 .env 并填入真实值
# ============================================================

# --- 应用密钥（生产环境务必更换）---
SECRET_KEY=your-secret-key-change-in-production

# --- MySQL 数据库 ---
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=fashion_db
MYSQL_PORT=3306

# --- 邮件服务（用于密码重置等功能）---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@yunxiangyishang.com

# --- 天气 API（聚合数据免费版）---
WEATHER_API_KEY=your-weather-api-key

# --- Ollama 本地 LLM（AI 时尚顾问）---
OLLAMA_MODEL=llama3.2:1b
